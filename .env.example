# My Gujarat Property — environment variable template.
# Copy to .env.local and fill in real values. .env.local is gitignored — never commit secrets.
# Optional provider groups resolve to SETUP_REQUIRED when unset; production
# fails safely at boot if a production-required variable is missing.

# ── Deployment stage and application hosts ────────────────
# DEPLOY_STAGE: development | staging | production (defaults from NODE_ENV)
DEPLOY_STAGE=
# Canonical public marketplace URL (required outside development)
NEXT_PUBLIC_APP_URL=
# Role application hosts (fall back to the public origin when unset)
NEXT_PUBLIC_BROKER_APP_URL=
NEXT_PUBLIC_BUILDER_APP_URL=
INTERNAL_APP_URL=

# ── Feature flags (server-authoritative; FLAG_<NAME>=true|false) ──
FLAG_BUILDER_HOMEPAGE_CAROUSEL=
FLAG_CITY_SEO_PAGES=
FLAG_BLOG=
FLAG_REQUIREMENTS_MARKETPLACE=
FLAG_IN_APP_NOTIFICATIONS=

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — bypasses RLS. Never expose to client code, logs, or docs.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
# Supabase management/CLI personal access token (CLI use only)
SUPABASE_ACCESS_TOKEN=

# ── SMS OTP provider (OTP delivery only) ──────────────────
SMS_OTP_PROVIDER=
SMS_OTP_API_KEY=

# ── Email provider (external notifications) ───────────────
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# ── Razorpay (payments) ───────────────────────────────────
# KEY_ID may be exposed to the client for checkout; SECRET + WEBHOOK_SECRET are server-only.
RAZORPAY_KEY_ID=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Must match the signing secret configured in the Razorpay dashboard webhook.
RAZORPAY_WEBHOOK_SECRET=

# ── Media storage and CDN ─────────────────────────────────
MEDIA_PROVIDER=
MEDIA_BUCKET=

# ── Analytics (optional, approved scope only) ─────────────
ANALYTICS_PROVIDER=

# ── Error monitoring (optional) ───────────────────────────
MONITORING_DSN=

# ── Scheduler / background jobs (optional) ────────────────
SCHEDULER_PROVIDER=

# ── Backup reference (optional) ───────────────────────────
BACKUP_REFERENCE=
